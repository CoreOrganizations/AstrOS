# AstrOS Agent Environment Configuration
# Copy this file to ~/.config/astros/agent.env and fill in your values

# OpenRouter API Configuration
ASTROS_API_KEY=your-api-key-here
ASTROS_BASE_URL=https://openrouter.ai/api/v1

# AI Model Configuration
ASTROS_AI_MODEL__NAME=mistralai/ministral-8b
ASTROS_AI_MODEL__MAX_TOKENS=2048
ASTROS_AI_MODEL__TEMPERATURE=0.7
ASTROS_AI_MODEL__TIMEOUT=60

# Logging
LOG_LEVEL=INFO
