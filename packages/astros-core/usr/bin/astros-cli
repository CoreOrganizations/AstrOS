#!/usr/bin/env bash
# AstrOS CLI - Command-line interface for AstrOS Agent
# This wrapper activates the virtualenv and runs the Python CLI

VENV_PATH="$HOME/.local/share/astros/venv"
CLI_SCRIPT="/usr/lib/astros/agent/astros_cli.py"

# Check if virtualenv exists
if [ ! -d "$VENV_PATH" ]; then
    echo "❌ AstrOS virtual environment not found!"
    echo "💡 Run: sudo dpkg-reconfigure astros-core"
    exit 1
fi

# Check if CLI script exists
if [ ! -f "$CLI_SCRIPT" ]; then
    echo "❌ AstrOS CLI script not found!"
    exit 1
fi

# Activate virtualenv and run CLI
exec "$VENV_PATH/bin/python3" "$CLI_SCRIPT" "$@"
